            color: #0d6efd;
            text-align: center;
            font-size: 24px;
            margin-bottom: 5px;
        }
        h2 {
            color: #64748b;
            text-align: center;
            font-size: 14px;
            font-weight: normal;
            margin-top: 0;
            margin-bottom: 30px;
        }
