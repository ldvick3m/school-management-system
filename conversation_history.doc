            margin-bottom: 25px;
            padding-bottom: 15px;
            border-bottom: 1px dashed #cbd5e1;
        }
        .user-header {
            color: #0d6efd;
            font-weight: bold;
            font-size: 14px;
            margin-bottom: 5px;
        }
